{
  "name": "intent-harness",
  "version": "0.1.0",
  "description": "AI coding harness — intent-first gate. Understand before you ship.",
  "type": "module",
  "bin": {
    "intent": "dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "intent": "node --loader ts-node/esm src/cli/index.ts"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
